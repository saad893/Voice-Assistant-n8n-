# ================================================
# Voice Assistant — Environment Variables Example
# ================================================
# Copy this file to .env and fill in your values.
# The standalone frontend uses localStorage (set via
# the ⚙ settings modal) — this file is for reference
# and any future server-side integration.

# Your n8n instance base URL (no trailing slash)
N8N_BASE_URL=https://your-n8n-instance.com

# Full URL to the process-audio webhook (from n8n)
# Displayed in the "Audio Processing Endpoint" node
WEBHOOK_VOICE_UI=https://your-n8n-instance.com/webhook/voice-assistant
WEBHOOK_PROCESS_AUDIO=https://your-n8n-instance.com/webhook/process-audio

# Your OpenAI API key
# Required for GPT-4o-mini (AI agent) and TTS (voice response)
OPENAI_API_KEY=sk-...

# Optional: OpenAI model override (default: gpt-4o-mini)
# OPENAI_MODEL=gpt-4o-mini

# Optional: OpenAI TTS voice (default: onyx)
# Options: alloy, echo, fable, onyx, nova, shimmer
# OPENAI_TTS_VOICE=onyx
